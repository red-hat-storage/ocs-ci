{
  "_comment": {
    "_comment": "Catalog of krknctl scenarios. Each node needs depends_on (string) except the root. Run 'krknctl describe <name>' for env schema."
  },

  "root": {
    "image": "quay.io/krkn-chaos/krkn-hub:dummy-scenario",
    "name": "dummy-scenario",
    "env": {
      "END": "10",
      "EXIT_STATUS": "0"
    }
  },

  "application-outages": {
    "image": "quay.io/krkn-chaos/krkn-hub:application-outages",
    "name": "application-outages",
    "env": {
      "BLOCK_TRAFFIC_TYPE": "[Ingress, Egress]",
      "DURATION": "600",
      "NAMESPACE": "{{ namespace }}",
      "POD_SELECTOR": "{{ pod_selector | default('{app: rook-ceph-mgr}') }}",
      "WAIT_DURATION": "60",
      "KRKN_DEBUG": "False"
    },
    "depends_on": "root"
  },

  "chaos-recommender": {
    "image": "quay.io/krkn-chaos/krkn-hub:chaos-recommender",
    "name": "chaos-recommender",
    "env": {
      "KRKN_DEBUG": "False"
    },
    "depends_on": "root"
  },

  "container-scenarios": {
    "image": "quay.io/krkn-chaos/krkn-hub:container-scenarios",
    "name": "container-scenarios",
    "env": {
      "ACTION": "1",
      "CONTAINER_NAME": "{{ container_name | default('') }}",
      "DISRUPTION_COUNT": "1",
      "EXPECTED_RECOVERY_TIME": "60",
      "LABEL_SELECTOR": "{{ label_selector | default('') }}",
      "NAMESPACE": "{{ namespace }}"
    },
    "depends_on": "root"
  },

  "dummy-scenario": {
    "image": "quay.io/krkn-chaos/krkn-hub:dummy-scenario",
    "name": "dummy-scenario",
    "env": {
      "END": "10",
      "EXIT_STATUS": "0"
    },
    "depends_on": "root"
  },

  "network-chaos": {
    "image": "quay.io/krkn-chaos/krkn-hub:network-chaos",
    "name": "network-chaos",
    "env": {
      "DURATION": "300",
      "EGRESS": "{bandwidth: 100mbit}",
      "EXECUTION": "parallel",
      "INSTANCE_COUNT": "1",
      "INTERFACES": "[]",
      "LABEL_SELECTOR": "node-role.kubernetes.io/worker=",
      "NETWORK_PARAMS": "{{ network_params | default('{latency: 50ms, loss: 0.02}') }}",
      "NODE_NAME": "{{ node_name | default('') }}",
      "TARGET_NODE_AND_INTERFACE": "{{ target_node_interface | default('{worker-0: [ens5]}') }}",
      "TRAFFIC_TYPE": "{{ traffic_type | default('egress') }}",
      "WAIT_DURATION": "300"
    },
    "depends_on": "root"
  },

  "node-cpu-hog": {
    "image": "quay.io/krkn-chaos/krkn-hub:node-cpu-hog",
    "name": "node-cpu-hog",
    "env": {
      "NAMESPACE": "{{ namespace }}",
      "NODE_CPU_CORE": "{{ node_cpu_core | default('2') }}",
      "NODE_CPU_PERCENTAGE": "{{ node_cpu_percentage | default('95') }}",
      "NODE_SELECTOR": "{{ node_selector | default('node-role.kubernetes.io/worker=') }}",
      "TOTAL_CHAOS_DURATION": "{{ duration | default('80') }}"
    },
    "depends_on": "root"
  },

  "node-io-hog": {
    "image": "quay.io/krkn-chaos/krkn-hub:node-io-hog",
    "name": "node-io-hog",
    "env": {
      "IO_BLOCK_SIZE": "1m",
      "IO_WORKERS": "5",
      "IO_WRITE_BYTES": "10m",
      "NAMESPACE": "{{ namespace }}",
      "NODE_SELECTOR": "{{ node_selector | default('node-role.kubernetes.io/worker=') }}",
      "TOTAL_CHAOS_DURATION": "{{ duration | default('60') }}"
    },
    "depends_on": "root"
  },

  "node-memory-hog": {
    "image": "quay.io/krkn-chaos/krkn-hub:node-memory-hog",
    "name": "node-memory-hog",
    "env": {
      "MEMORY_CONSUMPTION_PERCENTAGE": "{{ memory_percentage | default('90%') }}",
      "NAMESPACE": "{{ namespace }}",
      "NODE_SELECTOR": "{{ node_selector | default('node-role.kubernetes.io/worker=') }}",
      "NUMBER_OF_WORKERS": "{{ workers | default('1') }}",
      "TOTAL_CHAOS_DURATION": "{{ duration | default('80') }}"
    },
    "depends_on": "root"
  },

  "node-network-filter": {
    "image": "quay.io/krkn-chaos/krkn-hub:node-network-filter",
    "name": "node-network-filter",
    "env": {
      "NODE_SELECTOR": "{{ node_selector | default('node-role.kubernetes.io/worker=') }}",
      "NAMESPACE": "{{ namespace }}",
      "INSTANCE_COUNT": "1",
      "EXECUTION": "parallel",
      "INGRESS": "true",
      "EGRESS": "true",
      "PORTS": "{{ node_network_filter_ports | default('8080,8443') }}",
      "PROTOCOLS": "{{ node_network_filter_protocols | default('tcp') }}",
      "TOTAL_CHAOS_DURATION": "{{ duration | default('60') }}"
    },
    "depends_on": "root"
  },

  "pod-network-chaos": {
    "image": "quay.io/krkn-chaos/krkn-hub:pod-network-chaos",
    "name": "pod-network-chaos",
    "env": {
      "EGRESS_PORTS": "[]",
      "INGRESS_PORTS": "[]",
      "INSTANCE_COUNT": "1",
      "LABEL_SELECTOR": "{{ label_selector | default('') }}",
      "NAMESPACE": "{{ namespace }}",
      "TEST_DURATION": "120",
      "TRAFFIC_TYPE": "[ingress,egress]",
      "WAIT_DURATION": "300"
    },
    "depends_on": "root"
  },

  "pod-network-filter": {
    "image": "quay.io/krkn-chaos/krkn-hub:pod-network-filter",
    "name": "pod-network-filter",
    "env": {
      "NAMESPACE": "{{ namespace }}",
      "POD_SELECTOR": "{{ label_selector | default('app=rook-ceph-osd') }}",
      "INSTANCE_COUNT": "1",
      "EXECUTION": "parallel",
      "INGRESS": "true",
      "EGRESS": "true",
      "PORTS": "{{ pod_network_filter_ports | default('8080,8443') }}",
      "PROTOCOLS": "{{ pod_network_filter_protocols | default('tcp') }}",
      "TOTAL_CHAOS_DURATION": "{{ duration | default('60') }}"
    },
    "depends_on": "root"
  },

  "pod-scenarios": {
    "image": "quay.io/krkn-chaos/krkn-hub:pod-scenarios",
    "name": "pod-scenarios",
    "env": {
      "DISRUPTION_COUNT": "1",
      "EXPECTED_RECOVERY_TIME": "120",
      "KILL_TIMEOUT": "180",
      "NAMESPACE": "{{ namespace }}",
      "NAME_PATTERN": ".*",
      "POD_LABEL": "{{ pod_label | default(label_selector) }}",
      "WAIT_DURATION": "1"
    },
    "depends_on": "root"
  },

  "service-disruption-scenarios": {
    "image": "quay.io/krkn-chaos/krkn-hub:service-disruption-scenarios",
    "name": "service-disruption-scenarios",
    "env": {
      "DELETE_COUNT": "1",
      "LABEL_SELECTOR": "{{ label_selector | default('') }}",
      "NAMESPACE": "{{ namespace }}",
      "RUNS": "1"
    },
    "depends_on": "root"
  },

  "syn-flood": {
    "image": "quay.io/krkn-chaos/krkn-hub:syn-flood",
    "name": "syn-flood",
    "env": {
      "NAMESPACE": "{{ namespace }}",
      "TARGET_SERVICE_LABEL": "{{ label_selector | default('app=rook-ceph-osd') }}",
      "TARGET_PORT": "{{ syn_flood_target_port | default('8080') }}",
      "TOTAL_CHAOS_DURATION": "{{ duration | default('60') }}",
      "NUMBER_OF_PODS": "{{ syn_flood_number_of_pods | default('2') }}"
    },
    "depends_on": "root"
  }
}
