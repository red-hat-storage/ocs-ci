{
  "mcpServers": {
    "{{ mcp_server_name }}": {
      "command": "uv",
      "args": [
        "--directory",
        "{{ mcp_server_dir }}",
        "run",
        "ocs-ci-server"
      ],
      "env": {
        "OCS_CI_PATH": "{{ ocs_ci_dir }}"
      }
    }
  },
  "permissions": {
    "allow": [
      "Read({{ ocs_ci_dir }}/*)",
      "Read({{ mcp_server_dir }}/*)"
    ]
  },
  "autoApprove": [
    {
      "tool": "mcp__{{ mcp_server_name }}__*"
    }
  ]
}
