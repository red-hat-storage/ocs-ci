apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ deployment_name }}
  namespace: {{ namespace }}
  labels:
    app: {{ deployment_name }}
    workload-type: vdbench
spec:
  replicas: {{ replicas }}
  selector:
    matchLabels:
      app: {{ deployment_name }}
  template:
    metadata:
      labels:
        app: {{ deployment_name }}
        workload-type: vdbench
    spec:
      containers:
      - name: vdbench-container
        image: {{ image }}
        command: ["/bin/bash"]
        args:
        - "-c"
        - |
          echo "Starting Vdbench workload..."
          echo "Configuration file:"
          cp /config/vdbench.conf /tmp/vdbench.conf
          cat /tmp/vdbench.conf
          echo "================================"

          # Create a working directory with write permissions
          mkdir -p /tmp/vdbench-work
          cd /tmp/vdbench-work

{% if volume_mode == "Block" %}
          echo "Block device information:"
          ls -la {{ device_path }}
          lsblk {{ device_path }} || true
{% endif %}
          echo "Starting Vdbench execution..."
          # Run vdbench from the writable directory
          /vdbench/vdbench -f /tmp/vdbench.conf
          echo "Vdbench execution completed"
{% if volume_mode == "Block" %}
        volumeDevices:
        - name: vdbench-storage
          devicePath: {{ device_path }}
{% else %}
        volumeMounts:
        - name: vdbench-storage
          mountPath: {{ mount_path }}
{% endif %}
        - name: vdbench-config
          mountPath: /config
        resources:
          requests:
            memory: "1Gi"
            cpu: "500m"
          limits:
            memory: "2Gi"
            cpu: "1000m"
        env:
        - name: VDBENCH_OPTS
          value: "-Xmx1g"
{% if volume_mode == "Block" %}
        securityContext:
          privileged: true
{% endif %}
      volumes:
      - name: vdbench-storage
        persistentVolumeClaim:
          claimName: {{ pvc_name }}
      - name: vdbench-config
        configMap:
          name: {{ deployment_name }}-config
      restartPolicy: Always
